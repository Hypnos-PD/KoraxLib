# Copy this file to .env and adjust paths if your Steam library is elsewhere.

STS2_DIR="/home/user/.local/share/Steam/steamapps/common/Slay the Spire 2"
STS2_APP_ID="2868840"
STS2_RENDERER="opengl"

# Keep this enabled for KoraxLib smoke testing. Set to 0 for normal manual launches.
KORAXLIB_ENABLE_SMOKE_CONTENT="1"

# Enable lifecycle event logs while manually validating enemy lifecycle hooks.
KORAXLIB_ENABLE_LIFECYCLE_SMOKE="1"

# Enable the PowerTransfer SafeClone smoke runner in the smoke encounter.
KORAXLIB_ENABLE_POWER_TRANSFER_SMOKE="1"
